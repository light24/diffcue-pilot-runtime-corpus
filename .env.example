# Copy to .env. Keep DIFFCUE_TOKEN in the process environment; do not store it
# in this file. `make pilot-up` exchanges it for a short-lived runner token.
COMPOSE_PROJECT_NAME=diffcue-cue-pilot
PILOT_REPOSITORY=owner/repository
PILOT_REPO_DIR=/absolute/path/to/repository
DIFFCUE_SOURCE_DIR=/absolute/path/to/diffcue
DIFFCUE_COMMIT=d70adcd9a060fe5cb2a4d907b9e66c13840b3b24
DIFFCUE_PROVIDER_STORE=/var/lib/diffcue/provider-review
RUNNER_ARCH=arm64
RUNNER_NAME=diffcue-pilot-arm64
RUNNER_LABEL=diffcue-pilot
